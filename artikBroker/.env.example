# ── Artik Broker — environment template ──────────────────────────────────────
# Copy to .env (gitignored) or set in the App Runner service. NEVER commit real secrets.

# Core
ENVIRONMENT=development          # development | production
# APP_SECRET / APP_PASSWORD_HASH activate the auth gate when set (see DEPLOY.md)
# Break-glass admin recovery: set ADMIN_PASSWORD_RESET=<new-pw>, redeploy/restart to
# force-reset the admin password (works even with a populated persistent DB), then
# REMOVE it (it re-applies on every start while set). Requires deploy access.
# ADMIN_PASSWORD_RESET=

# Model / data provider keys (never exposed to the client)
ANTHROPIC_API_KEY=
OPENAI_API_KEY=
ALPHA_VANTAGE_API_KEY=

# ── Agent completion notifications → Artik Notifier → Slack #artik-notify ─────
# Every Artik Broker agent posts a completion event to the centralized Artik Notifier
# API on reaching a terminal state (completed/failed/cancelled/timeout/skipped).
NOTIFICATIONS_ENABLED=true
ARTIK_NOTIFY_API_URL=https://<artik-notifier-host>     # base URL of the Artik Notifier service
ARTIK_NOTIFY_API_KEY=<secure-api-key>                  # must match one of the Notifier's NOTIFY_API_KEYS
ARTIK_BROKER_APP_NAME=artikBroker
ARTIK_BROKER_BASE_URL=https://<artik-broker-host>      # used to build the "View Job" link
ARTIK_BROKER_VERSION=1.0.0
NOTIFICATION_TIMEOUT_SECONDS=10
NOTIFICATION_RETRY_COUNT=3

# ── E*TRADE brokerage connection (OAuth 1.0a) ─────────────────────────────────
# From the E*TRADE developer portal (https://developer.etrade.com). Secrets — set in
# the environment / Secrets Manager, NEVER commit real values.
ETRADE_CONSUMER_KEY=
ETRADE_CONSUMER_SECRET=
ETRADE_ENV=sandbox                # sandbox (apisb.etrade.com) | live (api.etrade.com)

# ── Charles Schwab Trader API (OAuth 2.0) ─────────────────────────────────────
# From developer.schwab.com (App Key + Secret). Register the callback URL exactly as
# below in your Schwab app. Secrets — env / Secrets Manager only, never commit.
SCHWAB_APP_KEY=
SCHWAB_APP_SECRET=
SCHWAB_REDIRECT_URI=https://<artik-broker-host>/api/schwab/callback   # defaults to ARTIK_BROKER_BASE_URL/api/schwab/callback
