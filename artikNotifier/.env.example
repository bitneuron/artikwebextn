# ── Artik Notifier — environment template ────────────────────────────────────
# Copy to .env and adjust. NEVER commit real secrets.

# App
ENVIRONMENT=development          # development | production
SECRET_KEY=change-me-to-a-long-random-string   # signs JWT session tokens
FRONTEND_URL=http://localhost:5173
CORS_ORIGINS=http://localhost:5173,http://localhost:8088

# Auth
ACCESS_TOKEN_EXPIRE_MINUTES=30
REFRESH_TOKEN_EXPIRE_DAYS=7
RATE_LIMIT_PER_MINUTE=120
# Comma-separated emails that receive the ADMIN role when they register (RBAC bootstrap).
ADMIN_EMAILS=
MIN_PASSWORD_LENGTH=8

# Database (SQLite by default; swap for Postgres/RDS later, no code change)
DATABASE_URL=sqlite:///./artik_notifier.db
# DATABASE_URL=postgresql+psycopg://user:pass@host:5432/artiknotifier

# Durable storage on AWS App Runner (no persistent disk): Litestream replicates the
# SQLite DB to S3 so accounts/reminders survive every redeploy. Set automatically by
# deploy.sh in prod; leave blank locally (→ ephemeral SQLite, no replication).
LITESTREAM_BUCKET=
LITESTREAM_REGION=us-west-2
# LITESTREAM_DB defaults to /data/artik_notifier.db in the container.

# Scheduler
SCHEDULER_ENABLED=true
SCHEDULER_INTERVAL_MINUTES=60
NOTIFICATION_MAX_RETRIES=3

# Email (SMTP). Leave SMTP_HOST blank in dev → emails are logged to console.
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
SMTP_FROM=Artik Notifier <no-reply@artiknotifier.local>
SMTP_USE_TLS=true
EMAIL_CONSOLE_FALLBACK=true

# Slack — set an Incoming Webhook URL to enable the "slack" notification channel.
# Leave blank → the channel is selectable but logs to console instead of posting.
SLACK_WEBHOOK_URL=

# Frontend (Vite) — blank uses the dev proxy /api → :8080
VITE_API_URL=

# Artik Platform (frontend) — cross-product landing/switcher. Optional overrides.
VITE_BROKER_URL=https://hpzkeypha3.us-west-2.awsapprunner.com
VITE_NOTIFIER_URL=/
VITE_APP_VERSION=1.0.0
VITE_APP_ENV=
