# Build context = superproject root, but the image only needs artikBroker +
# the artik_engine package. Keep the context small and KEEP PRIVATE DATA OUT.
.git
**/.git
**/__pycache__/
**/*.pyc
**/*.egg-info/
**/node_modules/
**/venv/
**/.venv/

# Other projects not part of the artikBroker image
artikAPIs/
artikTools/

# Private / not needed for the build
memory/
artikAgents/src/
artikAgents/agents/knowledge_bases/        # contains private Stock_Portfolio data
artikBroker/cache/                          # regenerable daily cache
artikBroker/search_history/                 # local dev history store (S3 used on AWS)
artikBroker/Dockerfile
artikBroker/DEPLOY.md
pokemon_battle.html
