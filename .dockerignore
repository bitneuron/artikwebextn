# Build context = superproject root, but the image only needs artikBroker +
# the artik_engine package. Keep the context small and KEEP PRIVATE DATA OUT.
.git
**/.git
**/__pycache__/
**/*.pyc
**/*.egg-info/
**/node_modules/
**/venv/
**/.venv/

# Other projects not part of the artikBroker image
artikAPIs/
artikTools/

# Private / not needed for the build
memory/
artikAgents/src/
# Exclude private knowledge bases (Stock_Portfolio etc.) but KEEP the stock-analysis
# methodology so Skills Management can read/edit the skill .md files in production.
artikAgents/agents/knowledge_bases/*
!artikAgents/agents/knowledge_bases/stock_analysis
# ArtikFinance: the personal financial statement workbook is the bundled import source
# (private ECR image, login-gated app — intended per the ArtikFinance spec).
!artikAgents/agents/knowledge_bases/personal_financial_statement
artikBroker/config/                         # runtime state (users.db, .app_secret, schedules) — never bake into the image
artikBroker/cache/                          # regenerable daily cache
artikBroker/search_history/                 # local dev history store (S3 used on AWS)
artikBroker/Dockerfile
artikBroker/DEPLOY.md
pokemon_battle.html
